{
    "name": "ipedis/rabbit-client-bundle",
    "description": "Symfony bundle for rabbit client",
    "type": "library",
    "authors": [
        {
            "name": "yanis",
            "email": "yanis@ipedis.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.2.0",
        "ipedis/rabbit-client": "^2.0.5",
        "symfony/dependency-injection": "^7.4",
        "symfony/config": "^7.4",
        "symfony/console": "^7.4",
        "symfony/http-kernel": "^7.4",
        "ext-json": "*",
        "symfony/monolog-bundle": "^4.0",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Ipedis\\Bundle\\Rabbit\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:ipedis/rabbit-client.git"
        },
        {
            "type": "vcs",
            "url": "git@github.com:ipedis/http-signature.git"
        }
    ],
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "require-dev": {
        "rector/rector": "^2.3"
    }
}
