{
    "name": "ipedis/rabbit-client-bundle",
    "description": "Symfony bundle for rabbit client",
    "type": "library",
    "authors": [
        {
            "name": "yanis",
            "email": "yanis@ipedis.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "ipedis/rabbit-client": "^1.0.0",
        "symfony/dependency-injection": "^4.0.10 || ^5.0",
        "symfony/config": "~4.0 || ^5.0",
        "symfony/http-kernel": "~4.0 || ^5.0"
    },
    "autoload": {
