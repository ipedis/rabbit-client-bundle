{
    "name": "ipedis/rabbit-client-bundle",
    "description": "Symfony bundle for rabbit client",
    "type": "library",
    "authors": [
        {
            "name": "yanis",
            "email": "yanis@ipedis.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=7.4.0",
        "ipedis/rabbit-client": "^2.0",
        "symfony/dependency-injection": "^5.0||^6.0",
        "symfony/config": "^5.0||^6.0",
        "symfony/console": "^5.0||^6.0",
        "symfony/http-kernel": "^5.0||^6.0",
        "ext-json": "*",
        "symfony/monolog-bundle": "^3.7",
        "pestphp/pest": "^1.18"
    },
    "autoload": {
        "psr-4": {
            "Ipedis\\Bundle\\Rabbit\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:ipedis/rabbit-client.git"
        },
        {
            "type": "vcs",
            "url": "git@github.com:ipedis/http-signature.git"
        }
    ]
}
